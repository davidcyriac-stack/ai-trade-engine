{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run AI Trade Engine",
      "type": "shell",
      "command": "uvicorn app.main:app --reload",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$python"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
